# Gmail SMTP — used by the contact form to send email.
# GMAIL_APP_PASSWORD is a 16-character App Password generated at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification).
GMAIL_USER=webtechhq@gmail.com
GMAIL_APP_PASSWORD=

# Address that receives contact form submissions (defaults to GMAIL_USER)
CONTACT_EMAIL=webtechhq@gmail.com

# Google reCAPTCHA v2 "I'm not a robot" checkbox
# Register a site at https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
