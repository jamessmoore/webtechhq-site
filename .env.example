# Address that receives contact form submissions (defaults to SENDGRID_FROM_EMAIL)
CONTACT_EMAIL=contact@example.com

# Google reCAPTCHA v2 "I'm not a robot" checkbox
# Register a site at https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ─── Questionnaire & Admin ────────────────────────────────────────────────────

# NextAuth.js — generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth — one Cloud project covers admin sign-in + One Tap pre-fill.
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
#                           https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin dashboard — only this Google account email can access /admin
ADMIN_EMAIL=admin@example.com

# Gold-standard test account — this account bypasses payment gates on every
# paid tool and can reset its own tool output to re-run the full funnel in
# production. No default - required for the bypass to activate anywhere.
TEST_ACCOUNT_EMAIL=test.account@example.com

# Accounts that can never be deleted from /admin (e.g. the admin account and
# the gold-standard test account above). Comma-separated list, no default -
# unset means no accounts are protected. Keep the real list private in your
# own .env.local only; do not put real addresses in this example file.
PROTECTED_ACCOUNT_EMAILS=

# SendGrid — transactional email (verification links, AI summaries, contact form)
# Create API key at https://app.sendgrid.com/settings/api_keys (Mail Send scope)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com

# Claude on Amazon Bedrock — used to generate Business Audit reports.
# Uses the standard AWS credential chain (shared ~/.aws/credentials, or
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY env vars) - no key stored here.
# Requires model access granted in the Bedrock console for the chosen model.
AWS_REGION=us-west-2
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# SQLite database file path (relative to project root, gitignored)
DATABASE_PATH=./data/submissions.db

# Journal entries API — machine-to-machine credential for Leo (the Media
# Pipeline agent) to POST new weekly Journal entries directly via
# POST /api/journal/entries, replacing the manual
# `npm run import:journal-entry` step. Not a user account, no default -
# the route returns 401 for every request until this is set. Generate with:
# openssl rand -hex 32
JOURNAL_API_KEY=

# ─── PayPal (Business Audit and other paid tools) ─────────────────────────────

# PayPal REST app credentials — https://developer.paypal.com/dashboard/applications
# PAYPAL_ENVIRONMENT / NEXT_PUBLIC_PAYPAL_ENVIRONMENT is "sandbox" (default) or "live" — keep them in sync
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox

# Webhook ID from the app's Webhooks section, once the listener URL is registered
PAYPAL_WEBHOOK_ID=

# ─── Analytics ─────────────────────────────────────────────────────────────────

# Google Analytics 4 measurement ID — https://analytics.google.com → Admin →
# Data Streams → your web stream. Not a secret, ships in the client bundle.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── Slack notifications ──────────────────────────────────────────────────────

# Incoming Webhook URL for the "website client activity" Slack channel.
# Create at https://api.slack.com/apps → your app → Incoming Webhooks →
# Add New Webhook to Workspace. Posts a message on signup, Opportunity Finder
# submission, Business Audit purchase, and Business Audit report ready.
SLACK_WEBHOOK_URL=
