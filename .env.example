# Gmail SMTP — used by the contact form to send email.
# GMAIL_APP_PASSWORD is a 16-character App Password generated at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification).
GMAIL_USER=webtechhq@gmail.com
GMAIL_APP_PASSWORD=

# Address that receives contact form submissions (defaults to GMAIL_USER)
CONTACT_EMAIL=webtechhq@gmail.com

# Google reCAPTCHA v2 "I'm not a robot" checkbox
# Register a site at https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ─── Questionnaire & Admin ────────────────────────────────────────────────────

# NextAuth.js — generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth — one Cloud project covers admin sign-in + One Tap pre-fill.
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
#                           https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin dashboard — only this Google account email can access /admin
ADMIN_EMAIL=webtechhq@gmail.com

# SendGrid — transactional email (verification links + AI summaries)
# Create API key at https://app.sendgrid.com/settings/api_keys (Mail Send scope)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@webtechhq.com

# Anthropic API — used to generate AI Opportunity Summaries for approved submissions
# Get key at https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# SQLite database file path (relative to project root, gitignored)
DATABASE_PATH=./data/submissions.db
